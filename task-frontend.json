{
    "family": "task-frontend",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "frontend",
            "image": "279404705013.dkr.ecr.us-east-1.amazonaws.com/innovatech-frontend:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "API_VENTAS_URL",
                    "value": "http://backend-ventas.ecs.local:8080"
                },
                {
                    "name": "API_DESPACHO_URL",
                    "value": "http://backend-despacho.ecs.local:8081"
                }
            ],
            "essential": true
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512"
}
